# ── Site (canonical URL for metadata/OG) ────
NEXT_PUBLIC_SITE_URL=https://example.xyz

# ── Supabase (Postgres + pgvector) ───────────────────────────────
# Project URL + keys from Supabase dashboard (API Keys).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Secret key — SERVER ONLY. Never expose to the client.
# (Legacy SUPABASE_SERVICE_ROLE_KEY is also accepted as a fallback.)
SUPABASE_SECRET_KEY=your-secret-key

# ── Generation: DeepSeek (OpenAI-compatible) ────────────────────
# Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-key
# OpenAI-compatible base URL. The /v1 is unrelated to the model version.
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Model id. env-overridable, eval-gated.
DEEPSEEK_MODEL=deepseek-chat

# ── Embeddings: OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=your-openai-key

# ── Contact form: Resend ────────────────────────────────────────
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-key
# Where recruiter messages are delivered (your inbox).
CONTACT_EMAIL=someemail@mail.com
# Verified sender. Use onboarding@resend.dev for testing (sends to
# your account email only); set a domain-verified address for prod.
RESEND_FROM=onboarding@resend.dev
